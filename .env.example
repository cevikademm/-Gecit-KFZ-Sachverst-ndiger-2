# ═══════════════════════════════════════════════════════════════
# Gecit KFZ Sachverständiger — Environment Variables (örnek)
# ═══════════════════════════════════════════════════════════════
# Bu dosyayı `.env` veya `.env.local` olarak kopyalayın ve gerçek
# değerleri yazın. `.env*` dosyaları .gitignore tarafından korunur.
# ═══════════════════════════════════════════════════════════════

# ─── Frontend (Vite) — istemci tarafı ─────────────────────────
# `VITE_` prefix'i Vite tarafından bundle'a dahil edilen değişkenleri belirtir.
# Browser'a sızar; sadece güvenli (anon) key kullanın.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# ─── AutoiXpert Import Script — sunucu tarafı ─────────────────
# Bu değişkenler SADECE Node.js script'leri içindir (scripts/autoixpert/*).
# `VITE_` prefix'i YOKTUR — bunlar browser'a sızmaz.

# AutoiXpert API base URL (versiyon dahil)
# Varsayılan: https://app.autoixpert.de/externalApi/v1
AUTOIXPERT_API_BASE_URL=https://app.autoixpert.de/externalApi/v1

# AutoiXpert API anahtarı (Bearer token)
# Müşterinin AutoiXpert hesabında: Einstellungen → Externe API → Neuer Zugangsschlüssel
# Önerilen izinler (least privilege, Faz 1 için yeterli):
#   - Gutachten: lesen
#   - Kontakte: lesen
#   - Rechnungen: lesen
AUTOIXPERT_API_KEY=

# Supabase service role key (RLS bypass eder — SADECE server-side!)
# Asla browser'a göndermeyin, asla VITE_ prefix'i ile saklamayın.
# Supabase Dashboard → Settings → API → service_role secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Opsiyonel: import davranışı ─────────────────────────────
# Her istekten sonra bekleme süresi (ms) — rate limit'e saygı
# Varsayılan: 200
AUTOIXPERT_REQUEST_DELAY_MS=200

# Hata durumunda max retry sayısı (4xx hariç)
# Varsayılan: 4
AUTOIXPERT_MAX_RETRIES=4

# Hangi resource'lar import edilsin (virgülle ayrılmış)
# Varsayılan: reports,contacts,invoices
# Tek tek test için: AUTOIXPERT_RESOURCES=contacts
AUTOIXPERT_RESOURCES=reports,contacts,invoices
